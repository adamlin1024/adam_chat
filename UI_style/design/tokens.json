{
  "$schema": "./tokens.schema.json",
  "meta": {
    "name": "Adam_chat Design Tokens",
    "version": "2.1.0",
    "mode": "dark-only",
    "style": "Linear-inspired · sharp · LINE-readable",
    "updated": "2026-04-20"
  },

  "color": {
    "bg": {
      "app":        { "value": "#08090b", "desc": "最外層 app 外框、icon 欄底色" },
      "sidebar":    { "value": "#0c0d10", "desc": "Session 列表欄背景" },
      "canvas":     { "value": "#0a0b0e", "desc": "主聊天區背景" },
      "surface":    { "value": "#141519", "desc": "active / hover 半透明狀態底色" },
      "overlay":    { "value": "#000000b3", "desc": "Modal / popover 背後遮罩（rgba 0,0,0,0.7）" },
      "elevated":   { "value": "#0c0d10", "desc": "Modal / dropdown / tooltip 卡片底色" }
    },

    "border": {
      "subtle":  { "value": "#18191d", "desc": "主要分隔線（欄位間、訊息間）" },
      "default": { "value": "#27272a", "desc": "按鈕、input、卡片邊框" },
      "strong":  { "value": "#3f3f46", "desc": "input focus / hover 邊框" }
    },

    "text": {
      "primary":   { "value": "#f4f4f5", "desc": "主要標題、使用者名稱、訊息內容強調" },
      "body":      { "value": "#d4d4d8", "desc": "訊息正文" },
      "secondary": { "value": "#a1a1aa", "desc": "次要文字、reaction 計數" },
      "muted":     { "value": "#71717a", "desc": "名稱下方預覽、置灰互動文字" },
      "subtle":    { "value": "#52525b", "desc": "placeholder、圖示、不可點擊的標籤" },
      "disabled":  { "value": "#3f3f46", "desc": "section label、時間戳、幾乎看不到的輔助文字" }
    },

    "accent": {
      "teal-300":  { "value": "#5eead4", "desc": "★ 主色 · 頭像、active 狀態、連結、送出按鈕底色" },
      "teal-400":  { "value": "#2dd4bf", "desc": "hover / 懸浮強化" },
      "teal-500":  { "value": "#14b8a6", "desc": "pressed / 長時間狀態" },
      "teal-on":   { "value": "#042f2e", "desc": "在 teal 上層的文字顏色（深色）" },
      "teal-bg":   { "value": "#5eead415", "desc": "teal 的 15% 半透明背景（reaction mine、quote）" },
      "teal-border": { "value": "#5eead430", "desc": "teal 的半透明 border" }
    },

    "semantic": {
      "online":   { "value": "#4ade80", "desc": "在線圓點" },
      "idle":     { "value": "#fbbf24", "desc": "閒置" },
      "offline":  { "value": "#52525b", "desc": "離線" },
      "danger":   { "value": "#f87171", "desc": "刪除 / 錯誤文字" },
      "danger-bg":{ "value": "#ef4444", "desc": "刪除按鈕底色" },
      "warning":  { "value": "#fbbf24", "desc": "警告" }
    },

    "avatar-fallback": {
      "desc": "無頭像時依使用者 id 選一個；channel 用 channel-blue。",
      "user-teal":   "#5eead4",
      "user-green":  "#10b981",
      "user-purple": "#8b5cf6",
      "user-pink":   "#ec4899",
      "user-orange": "#f97316",
      "user-blue":   "#3b82f6",
      "channel-blue":"#3b82f6"
    }
  },

  "typography": {
    "family": {
      "sans": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang TC', 'Noto Sans TC', sans-serif",
      "mono": "'JetBrains Mono', 'SF Mono', Menlo, Consolas, monospace"
    },
    "size": {
      "xs":   { "value": "11px",   "line": "1.4",  "use": "section label (mono, uppercase) / keyboard hint" },
      "sm":   { "value": "12px",   "line": "1.5",  "use": "timestamp (mono) / badge / role chip / reaction" },
      "base": { "value": "14.5px", "line": "1.5",  "use": "input text / secondary body" },
      "md":   { "value": "15px",   "line": "1.55", "use": "訊息正文 / 使用者名稱 / session item name（★ 主體尺寸）" },
      "lg":   { "value": "16px",   "line": "1.4",  "use": "chat header title" },
      "xl":   { "value": "17px",   "line": "1.4",  "use": "modal title / login title" },
      "2xl":  { "value": "20px",   "line": "1.3",  "use": "page title（members / settings）" }
    },
    "weight": {
      "regular":  400,
      "medium":   500,
      "semibold": 600,
      "bold":     700
    },
    "letter-spacing": {
      "tight":  "-0.015em",
      "normal": "-0.005em",
      "wide":   "0.05em",
      "mono":   "0.08em",
      "caps":   "0.14em"
    }
  },

  "radius": {
    "sm":   "4px",
    "md":   "6px",
    "lg":   "8px",
    "xl":   "10px",
    "pill": "9999px",
    "desc": "整體走小圓角。avatar user → pill；avatar channel → md；button → sm/md；card → lg。"
  },

  "spacing": {
    "0": "0",
    "1": "2px",
    "2": "4px",
    "3": "6px",
    "4": "8px",
    "5": "10px",
    "6": "12px",
    "7": "14px",
    "8": "16px",
    "10": "20px",
    "12": "24px"
  },

  "layout": {
    "icon-bar-width":    "60px",
    "session-width":     "260px",
    "chat-header-height":"56px",
    "hit-target-min":    "36px",
    "density":           "comfortable"
  },

  "shadow": {
    "none":     "none",
    "overlay":  "0 20px 50px #00000080",
    "dropdown": "0 8px 24px #00000066",
    "inset-hairline": "inset 0 0 0 1px #27272a"
  },

  "motion": {
    "duration-fast":   "120ms",
    "duration-base":   "180ms",
    "easing-standard": "cubic-bezier(0.4, 0.0, 0.2, 1)",
    "desc": "動效克制。狀態切換用 fast；modal / drawer 用 base。不加 spring。"
  }
}
