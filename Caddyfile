:3000 {
    root * /app/wwwroot
    encode gzip

    handle /api/* {
        reverse_proxy localhost:3001 {
            flush_interval -1
        }
    }

    handle /apple-touch-icon.png {
        redir /api/resource/organization/logo 302
    }

    # SW 實際檔名是 sw.js；不快取，每次都要驗證最新
    handle /sw.js {
        header Cache-Control "no-cache, no-store, must-revalidate"
        file_server
    }

    # 貼圖：快取 5 分鐘 + 必須 revalidate（靠 ETag 走 304）
    # 移除原本的 immutable，避免 iOS Safari / PWA 永久卡舊檔
    handle /stickers/* {
        header Cache-Control "public, max-age=300, must-revalidate"
        file_server
    }

    handle {
        try_files {path} {path}/ /index.html
        file_server
    }
}
